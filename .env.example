# ════════════════════════════════════════════════════════════════
# FABER – Atelier de Consultanță | .env.example
# Copiați acest fișier în .env și completați valorile reale.
# NICIODATĂ nu commit-ați fișierul .env în repository!
# ════════════════════════════════════════════════════════════════

# ── ADMIN AUTH ────────────────────────────────────────────────
# Generați hash-ul cu: php -r "echo password_hash('parola_ta', PASSWORD_BCRYPT);"
ADMIN_EMAIL=admin@exemplu.ro
ADMIN_PASSWORD_HASH=$2y$12$HASH_GENERAT_CU_PASSWORD_HASH

# ── EMAIL CONTACT FORM ─────────────────────────────────────────
# Adresa la care ajung mesajele de pe formular
CONTACT_TO_EMAIL=contact@atelierdeconsultanta.ro
CONTACT_FROM_NAME=FABER - Website
# Opțional: SMTP dacă serverul nu suportă mail()
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=email@gmail.com
# SMTP_PASS=app_password

# ── GITHUB (stocat server-side, nu expus în frontend) ─────────
# GH_PAT=ghp_xxxxxxxxxxxxxxxxxxxx
# GH_OWNER=username
# GH_REPO=repository-name
# GH_BRANCH=main

# ── SECURITATE ────────────────────────────────────────────────
# Cheie secretă pentru tokens CSRF (generați aleator: openssl rand -hex 32)
SECRET_KEY=INLOCUITI_CU_STRING_ALEATOR_LUNG
